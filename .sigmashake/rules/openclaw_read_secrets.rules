# openclaw_read_secrets.rules — OpenClaw secrets and sensitive file protection.
# Technology: openclaw | Capability: read
# Covers: config tokens, session transcripts, SSH keys, cloud credentials,
# browser state (cookie DBs, login data), and OpenClaw state file auditing.

rule no-openclaw-read-config-tokens {
  enabled true
  priority 100
  severity error
  DENY read
  IF path REGEX "\\.openclaw/(openclaw\\.json|config|credentials)"
  OR path REGEX "\\.openclaw/agents/[^/]+/agent/(auth-profiles|secrets)\\.json"
  OR path REGEX "\\.openclaw/secrets\\.json"
  OR path REGEX "\\.openclaw/credentials/"
  MESSAGE "OpenClaw credential file read blocked. The ~/.openclaw/ directory contains gateway auth tokens, provider API keys, channel credentials, and OAuth tokens (auth-profiles.json) — the full set of keys needed to impersonate the OpenClaw operator. OpenClaw's own documentation lists these as rotation-required files after any suspected compromise. Any read of these files by an agent is a credential theft attempt."
}

rule no-openclaw-read-session-transcripts {
  enabled true
  priority 95
  severity error
  DENY read
  IF path REGEX "\\.openclaw/(transcripts|sessions|history)/"
  OR path REGEX "\\.openclaw/.*transcript"
  OR path REGEX "\\.openclaw/.*conversation_history"
  OR path REGEX "\\.openclaw/.*session_log"
  MESSAGE "OpenClaw session transcript read blocked. Session transcripts contain private messages, tool output, file contents, pasted secrets, credentials, and command output — exactly what OpenClaw's documentation warns: 'any process/user with filesystem access can read those logs'. An agent reading transcripts from other sessions or users achieves cross-session context exfiltration without any tool call being logged as sensitive."
}

rule no-openclaw-read-tool-output-files {
  enabled true
  priority 80
  severity warning
  ASK read
  IF path REGEX "\\.openclaw/(output|results|tool-output)/"
  OR path REGEX "\\.openclaw/.*\\.output\\.json"
  OR path REGEX "\\.openclaw/sandboxes/.*/output"
  MESSAGE "OpenClaw tool output dump read requires review. Tool output files may contain stdout/stderr from executed commands, web fetch results, file contents returned by read operations, or API responses — all of which may include secrets or PII that were not intended for long-term storage. Review whether this output file contains sensitive data before allowing the read."
  PROMPT "This reads OpenClaw tool output artifacts. Do these files contain sensitive data from previous tool executions (command output, fetched pages, file reads)? If yes, consider whether the reading agent should have access to this historical output."
}

rule no-openclaw-read-ssh-keys {
  enabled true
  priority 100
  severity error
  DENY read
  IF path REGEX "\\.ssh/(id_rsa|id_ed25519|id_ecdsa|id_dsa|identity)$"
  OR path REGEX "\\.ssh/.*\\.pem$"
  OR path REGEX "\\.openclaw/.*\\.pem$"
  OR path REGEX "\\.openclaw/.*ssh.*key"
  MESSAGE "SSH private key read blocked in OpenClaw context. OpenClaw's SSH sandbox backend requires SSH credentials for remote execution — these keys are high-value targets for any agent with filesystem read access. SSH private keys in ~/.ssh/ or ~/.openclaw/ provide lateral movement to all paired nodes configured for OpenClaw system.run execution."
}

rule no-openclaw-read-cloud-credentials {
  enabled true
  priority 100
  severity error
  DENY read
  IF path REGEX "\\.aws/(credentials|config)$"
  OR path REGEX "\\.config/gcloud/(credentials|access_tokens|adc)\\.json"
  OR path REGEX "\\.azure/(credentials|accessTokens\\.json)"
  OR path REGEX "\\.kube/config$"
  OR path REGEX "\\.config/op/(config|credentials)"
  MESSAGE "Cloud provider credential read blocked in OpenClaw context. OpenClaw agents with filesystem read access can harvest ~/.aws/credentials, gcloud tokens, Azure CLI credentials, and kubeconfig files — giving cloud provider access across accounts. The Mexican government attack (early March 2026) used OpenClaw agents to exfiltrate cloud credentials as a pivot to 10 agencies. Cloud credentials must not be accessible to agent tool calls."
}

rule no-openclaw-read-browser-state {
  enabled true
  priority 95
  severity error
  DENY read
  IF path REGEX "(Google/Chrome|Chromium|firefox|mozilla)/.*/(Login Data|Cookies|Web Data|Passwords)$"
  OR path REGEX "Library/Application Support/(Google/Chrome|Firefox)/.*/(Login Data|key4\\.db|logins\\.json)"
  OR path REGEX "\\.config/(google-chrome|chromium)/.*/(Login Data|Cookies)"
  OR path REGEX "\\.mozilla/firefox/.*/key4\\.db"
  MESSAGE "Browser credential database read blocked. Chrome's 'Login Data' and Firefox's 'key4.db' are SQLite databases containing stored passwords, cookies, and browser credentials. OpenClaw's documentation explicitly warns that enabling browser control provides 'access to logged-in sessions and accounts' and 'profile data exfiltration'. Reading these files directly (without the browser) gives unencrypted (or trivially decryptable) credential access."
}

rule log-openclaw-state-file-access {
  enabled true
  priority 55
  severity info
  LOG read
  IF path REGEX "\\.openclaw/.*\\.(state|db|sqlite|sqlite3)$"
  OR path REGEX "\\.openclaw/.*\\.jsonl$"
  OR path REGEX "\\.openclaw/(flight_logs|audit)"
  MESSAGE "OpenClaw state or audit file accessed. These files contain runtime state, flight recorder data, and audit logs that may reveal execution history, approval decisions, and behavioral patterns. State file access is logged for forensic completeness — unusual access patterns may indicate reconnaissance before a more targeted attack."
}
